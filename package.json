{
  "name": "@kunalnagarco/jquery-peek-a-bar",
  "version": "5.0.0",
  "description": "A jQuery plugin for a notification bar with a lot of customization options.",
  "main": "dist/js/jquery.peekabar.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "prebuild": "rm -rf dist",
    "build": "npm run build:js && npm run build:css",
    "build:js": "esbuild src/js/peekabar.js --platform=browser --outfile=dist/js/jquery.peekabar.js && esbuild src/js/peekabar.js --platform=browser --minify --sourcemap --outfile=dist/js/jquery.peekabar.min.js",
    "build:css": "sass src/scss/peekabar.scss dist/css/jquery.peekabar.css && sass src/scss/peekabar.scss dist/css/jquery.peekabar.min.css --style=compressed --source-map",
    "watch:js": "esbuild src/js/peekabar.js --platform=browser --minify --sourcemap --outfile=dist/js/jquery.peekabar.min.js --watch",
    "watch:css": "sass --watch src/scss/peekabar.scss dist/css/jquery.peekabar.min.css --style=compressed --source-map",
    "release": "semantic-release"
  },
  "author": "Kunal Nagar <knlnagar@gmail.com>",
  "license": "MIT",
  "devDependencies": {
    "@semantic-release/changelog": "6.0.3",
    "@semantic-release/commit-analyzer": "13.0.1",
    "@semantic-release/git": "10.0.1",
    "@semantic-release/github": "12.0.6",
    "@semantic-release/npm": "13.1.5",
    "@semantic-release/release-notes-generator": "14.1.0",
    "conventional-changelog-conventionalcommits": "9.1.0",
    "esbuild": "0.25.2",
    "prettier": "3.8.1",
    "sass": "1.99.0",
    "semantic-release": "25.0.3"
  },
  "keywords": [
    "jquery-plugin",
    "ecosystem:jquery"
  ],
  "repository": {
    "type": "git",
    "url": "git://github.com/kunalnagarco/jquery.peekABar.git"
  },
  "publishConfig": {
    "access": "public"
  }
}
